// Vercel KV / Upstash Redis implementation of checkRateLimit.
//
// To activate:
//   1. npm install @vercel/kv
//   2. Rename this file to `rate-limit.ts` (replace the in-memory version).
//   3. Ensure KV_REST_API_URL and KV_REST_API_TOKEN are set (the Vercel KV
//      integration sets these automatically when linked to the project).
//   4. checkRateLimit becomes async — update the four call sites in
//      app/api/*/route.ts to `await checkRateLimit(...)`.

import { kv } from "@vercel/kv";

type RateLimitOptions = {
  limit: number;
  windowMs: number;
};

type RateLimitResult = {
  allowed: boolean;
  remaining: number;
  resetAt: number;
};

// Fixed-window counter via INCR + PEXPIRE. The first hit in a window sets
// the TTL; subsequent hits in the same window just increment.
export async function checkRateLimit(
  key: string,
  options: RateLimitOptions,
): Promise<RateLimitResult> {
  const bucketKey = `rl:${key}:${Math.floor(Date.now() / options.windowMs)}`;
  const count = await kv.incr(bucketKey);

  if (count === 1) {
    await kv.pexpire(bucketKey, options.windowMs);
  }

  const ttl = await kv.pttl(bucketKey);
  const resetAt = Date.now() + (ttl > 0 ? ttl : options.windowMs);

  if (count > options.limit) {
    return { allowed: false, remaining: 0, resetAt };
  }

  return {
    allowed: true,
    remaining: Math.max(0, options.limit - count),
    resetAt,
  };
}