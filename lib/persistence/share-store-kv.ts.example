// Vercel KV / Upstash Redis implementation of the share store.
//
// To activate:
//   1. npm install @vercel/kv
//   2. Rename this file to `share-store.ts` (replace the in-memory version).
//   3. In the Vercel dashboard, create a KV store and link it to the project.
//      That auto-populates KV_REST_API_URL and KV_REST_API_TOKEN.
//   4. Note: putShare/getShare become async — all callers already await Promises,
//      but verify the import sites compile.

import { kv } from "@vercel/kv";

import type { ProjectBriefWithStarter } from "@/lib/ai/planner-schema";

export type SharedBrief = {
  id: string;
  idea: string;
  model: string | null;
  brief: ProjectBriefWithStarter;
  createdAt: number;
};

const KEY_PREFIX = "share:";
const TTL_SECONDS = 60 * 60 * 24 * 30; // 30 days

export function newShareId(): string {
  return crypto.randomUUID();
}

export async function putShare(record: SharedBrief): Promise<void> {
  await kv.set(`${KEY_PREFIX}${record.id}`, record, { ex: TTL_SECONDS });
}

export async function getShare(id: string): Promise<SharedBrief | null> {
  const record = await kv.get<SharedBrief>(`${KEY_PREFIX}${id}`);
  return record ?? null;
}
